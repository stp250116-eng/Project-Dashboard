{
  "name": "enterprise-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enterprise Dashboard aggregating internal APIs and Jira data",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@progress/kendo-data-query": "^1.7.0",
    "@progress/kendo-drawing": "^1.21.2",
    "@progress/kendo-licensing": "^1.4.0",
    "@progress/kendo-react-buttons": "^9.3.1",
    "@progress/kendo-react-charts": "^9.3.1",
    "@progress/kendo-react-dropdowns": "^9.3.1",
    "@progress/kendo-react-grid": "^9.3.1",
    "@progress/kendo-react-inputs": "^9.3.1",
    "@progress/kendo-react-intl": "^9.3.1",
    "@progress/kendo-react-layout": "^9.3.1",
    "@progress/kendo-svg-icons": "^4.0.0",
    "@progress/kendo-theme-default": "^10.3.1",
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "sass": "^1.101.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.9"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
